        "googleSheetsOAuth2Api": {
          "id": "KiIFBovsLWhz9ZoM",
          "name": "Google Sheets account"
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all(); const errorItem = items.find((item) => item.json && item.json.error); let error = null; if (errorItem) { const raw = errorItem.json.error; error = typeof raw === 'string' ? raw : (raw.message || JSON.stringify(raw)); } return [{ json: { credential: 'Google Sheets account', type: 'googleSheetsOAuth2Api', ok: !error, error: error, checkedAt: new Date().toISOString() } }];"
      },
      "name": "Normalize Google Sheets Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        304,
        -80
      ],
      "id": "4733d923-d5cf-4e50-a3c9-c507e6512590"
    },
    {
      "parameters": {
        "jsCode": "const checks = $input.all().map((item) => item.json); const failed = checks.filter((check) => !check.ok); const lines = checks.map((check) => check.ok ? 'OK - ' + check.credential + ' (' + check.type + ')' : 'FAIL - ' + check.credential + ' (' + check.type + '): ' + (check.error || 'unknown error')); const header = failed.length === 0 ? '[system] n8n credential daily check: all credentials are healthy' : '[system] n8n credential daily check: ' + failed.length + ' credential(s) failed'; const message = header + '\\n\\nRun timestamp: ' + new Date().toISOString() + '\\nTotal checks: ' + checks.length + '\\nFailures: ' + failed.length + '\\n\\n' + lines.join('\\n') + '\\n\\n' + (failed.length === 0 ? 'Status: all credentials are working.' : 'Status: please inspect and reauthorize the failing credential(s) in n8n.'); return [{ json: { message: message, failedCount: failed.length, totalChecks: checks.length, checks: checks } }];"
      },
      "name": "Build Health Summary",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
